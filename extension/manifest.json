{
  "manifest_version": 3,
  "name": "Job Engine Companion",
  "version": "1.0.0",
  "description": "Fills job applications in your own browser, driven by your local Job Engine app. Never clicks, never submits — you always do that.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content/click_guard.js",
        "content/scanner.js",
        "content/filler.js",
        "content/overlay.js",
        "content/main.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Job Engine Companion"
  },
  "web_accessible_resources": []
}
