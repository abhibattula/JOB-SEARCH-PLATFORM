# LLM provider (OpenAI-compatible). Defaults target the Groq free tier.
# Get a free key at https://console.groq.com — no card required.
# The app runs without a key; jobs just stay unscored.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# SQLite location. Must be on a LOCAL disk (WAL mode does not work on network drives).
JOBS_DB_PATH=data/jobs.db

# jobspy is best-effort: Indeed always runs; LinkedIn only when set to 1 (bot-blocks often).
JOBSPY_LINKEDIN=0

# Set to 1 to run an automatic nightly refresh while the app is running.
SCHEDULE_REFRESH=0

# Cap LLM scoring calls per refresh run (protects the free-tier daily quota).
MAX_SCORE_PER_RUN=150
